# === Supabase ===
# 從 Supabase Dashboard → Settings → API 取得
NEXT_PUBLIC_SUPABASE_URL=https://你的專案id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的anon_key

# === Google Gemini AI ===
# 從 https://aistudio.google.com/apikey 取得
GEMINI_API_KEY=你的gemini_api_key

# === 管理員密碼 ===
# 你自己設定一個密碼，用來進入管理後台
ADMIN_PASSWORD=你的管理密碼

# === 匯率 API（免費） ===
# 從 https://www.exchangerate-api.com/ 免費註冊取得
EXCHANGE_RATE_API_KEY=你的匯率api_key
